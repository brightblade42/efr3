HOST_IP=192.168.3.174
PROCESSOR_PV_HTTP_INTERFACE=on
PROCESSOR_PV_INFERENCE_WORKERS=1

PVDB_POSTGRES_USER=admin
PVDB_POSTGRES_PWD=admin
PVDB_POSTGRES_DB=identity
#may be deprecated
PVDB_PV_DATA_VOL=/opt/eyemetric/fr/data/pvdb_pgdata/_data:/var/lib/postgresql/data:Z

IDENT_POSTGRES_URI=postgresql://admin:admin@${HOST_IP}:5432/identity?sslmode=disable
IDENT_HTTP_PROXY=on

#stream
STREAM_TZ=EST
STREAM_PV_OUTPUT_FACES_ONLY=True
STREAM_PV_POSTPROCESSOR_WORKERS=1
STREAM_PV_INFERENCE_WORKERS=1
STREAM_PV_FACE_QUALITY_TRACKING=0.5

